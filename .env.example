# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_FROM=your-sender@example.com
EMAIL_TO=your-inbox@example.com

# ── SMTP (examples below — pick one and fill in your credentials) ──────────────

# Gmail — requires an App Password (not your Google account password)
# Enable App Passwords: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # 16-character App Password

# Outlook / Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@outlook.com
# SMTP_PASSWORD=your-password

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxx...         # your SendGrid API key

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@mg.yourdomain.com
# SMTP_PASSWORD=your-mailgun-smtp-password

# ── Optional tuning ────────────────────────────────────────────────────────────
# How many hours back to look for news (default: 24)
HOURS_BACK=24
