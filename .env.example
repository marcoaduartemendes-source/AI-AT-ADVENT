# ── Anthropic ──────────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (used by daily digest feature) ──────────────────────────────────────
EMAIL_FROM=your-sender@example.com
EMAIL_TO=your-inbox@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Alert sender ──────────────────────────────────────────────────────────────
# Required when ALERT_EMAIL_TO is set. No hardcoded default — set this
# explicitly to the address you authenticate as via SMTP_PASSWORD.
SMTP_FROM=alerts@example.com

# ── Healthchecks.io dead-man's switch ─────────────────────────────────────────
# Optional. When set, the orchestrator / scouts / dashboard / db-backup
# ping start/success/fail at each cycle so a crashed runner surfaces
# via Healthchecks alerting (out-of-band from in-process alert sinks).
# Create at https://healthchecks.io and paste the per-check ping URL.
# HEALTHCHECKS_PING_URL_ORCHESTRATOR=https://hc-ping.com/...
# HEALTHCHECKS_PING_URL_SCOUTS=https://hc-ping.com/...
# HEALTHCHECKS_PING_URL_DASHBOARD=https://hc-ping.com/...
# HEALTHCHECKS_PING_URL_DB_BACKUP=https://hc-ping.com/...

# ── Live-trading safety ───────────────────────────────────────────────────────
# Two-key guard: even with DRY_RUN=false, the orchestrator refuses
# to place real orders unless ALLOW_LIVE_TRADING=1. Forces an explicit
# decision rather than one stale toggle going live.
# ALLOW_LIVE_TRADING=1

# ── Coinbase Advanced Trade API ────────────────────────────────────────────────
# Create API keys at https://www.coinbase.com/settings/api
# Permissions needed: "View" + "Trade"  (do NOT enable Transfer)
#
# New Coinbase keys are CDP / JWT (recommended):
#   COINBASE_API_KEY takes the form "organizations/.../apiKeys/..."
#   COINBASE_API_SECRET is an EC P-256 PEM private key.
#   Wrap the PEM in DOUBLE QUOTES and use literal \n between lines, e.g.:
#   COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nMHcCAQE...\n-----END EC PRIVATE KEY-----\n"
#
# Legacy HMAC keys are also auto-detected — paste the raw key + base64 secret.
COINBASE_API_KEY=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END EC PRIVATE KEY-----\n"

# ── Trading configuration ──────────────────────────────────────────────────────

# Paper trading (no real orders). Set to false ONLY when ready for live trading.
DRY_RUN=true

# Maximum USD spent per single order (hard-capped at $20 for safety)
MAX_TRADE_USD=20.0

# Minimum signal confidence required to act (0.0–1.0). 0.6 is a good starting point.
MIN_CONFIDENCE=0.6

# How often to scan all products (minutes). 60 = once per hour.
SCAN_INTERVAL_MINUTES=60

# Comma-separated Coinbase product IDs to trade
TRADING_PRODUCTS=BTC-USD,ETH-USD,SOL-USD

# Optional: custom path for the SQLite performance database
# TRADING_DB_PATH=data/trading_performance.db

# ── Daily digest tuning ────────────────────────────────────────────────────────
HOURS_BACK=24
