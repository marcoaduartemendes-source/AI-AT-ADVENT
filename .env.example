# ── Anthropic ────────────────────────────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (used by daily digest + cash flow report) ──────────────────────────────
EMAIL_FROM=your-sender@example.com
EMAIL_TO=your-inbox@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Monarch Money ───────────────────────────────────────────────────────────────────
# Your Monarch Money login credentials (read-only access).
# Monarch aggregates all your linked accounts, so enabling this source
# alone covers most bank + credit card history.
MONARCH_EMAIL=your@email.com
MONARCH_PASSWORD=yourpassword

# Optional: TOTP secret for 2-factor auth.
# Find it in your authenticator app settings (the seed/secret key, not the 6-digit code).
MONARCH_MFA_SECRET=

# ── Chase Bank via Plaid ───────────────────────────────────────────────────────────
# Chase has no direct consumer API, so we use Plaid as the bridge.
#
# Setup (one-time, ~5 minutes):
#   1. Sign up free at https://dashboard.plaid.com
#   2. Copy your Client ID + Secret below.
#   3. Run:  python scripts/plaid_link_setup.py
#      A browser window will open; log in with your Chase credentials.
#   4. Copy the printed PLAID_ACCESS_TOKEN here and into GitHub Secrets.
#
# Note: If Monarch Money is already linked to your Chase account, Plaid
# data will be deduplicated automatically — no double counting.
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ACCESS_TOKEN=access-production-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLAID_ENV=production   # or: sandbox (for testing with fake data)

# ── Rocket Money ───────────────────────────────────────────────────────────────────
# Rocket Money has no public API.
# Export your transaction history from the app:
#   App → Settings → Export Data → Transactions CSV
# Then set the path to the downloaded file below.
# Leave blank to skip Rocket Money (use Monarch or Plaid instead).
ROCKET_MONEY_CSV_PATH=
# example: ROCKET_MONEY_CSV_PATH=data/rocket_money_transactions.csv

# ── Cash flow forecast settings ────────────────────────────────────────────────────
# Days of transaction history to analyse for pattern detection.
CASHFLOW_LOOKBACK_DAYS=90

# Number of weeks to project (default 13 = one quarter).
CASHFLOW_FORECAST_WEEKS=13

# Your current total cash balance across all checking/savings accounts.
# If set, this anchors the opening balance for week 1.
# If left blank AND Monarch is configured, the live balance is fetched automatically.
CURRENT_BALANCE=

# ── Coinbase Advanced Trade API ───────────────────────────────────────────────────────
COINBASE_API_KEY=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END EC PRIVATE KEY-----\n"

# ── Trading configuration ────────────────────────────────────────────────────────────
DRY_RUN=true
MAX_TRADE_USD=20.0
MIN_CONFIDENCE=0.6
SCAN_INTERVAL_MINUTES=60
TRADING_PRODUCTS=BTC-USD,ETH-USD,SOL-USD

# ── Daily digest tuning ───────────────────────────────────────────────────────────────
HOURS_BACK=24
