# /etc/aaa.env — environment for the AI-AT-ADVENT systemd services.
#
# Each line is KEY=VALUE. No quotes around values (systemd parses them
# literally). Lines starting with # are comments. Whitespace around
# the = is NOT allowed in systemd's EnvironmentFile syntax.
#
# Permissions: this file should be 0600 owned by root:aaa.
# install.sh sets that automatically.
#
# Copy each value from your GitHub Actions secrets (where they're
# already set):
#   https://github.com/marcoaduartemendes-source/AI-AT-ADVENT/settings/secrets/actions
#
# To rotate any value: just edit this file and `systemctl restart
# orchestrator.service` (or wait for the next timer tick).

# ─── Brokers ────────────────────────────────────────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=
ALPACA_API_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY=
KALSHI_ENDPOINT=https://api.elections.kalshi.com/trade-api/v2

# ─── LLM (strategic reviewer + scouts that use Claude) ─────────────────
ANTHROPIC_API_KEY=

# ─── Backtest data vendor (FMP — formerly Polygon-only) ────────────────
FMP_API_KEY=

# ─── Trading config ────────────────────────────────────────────────────
DRY_RUN=true
DRY_RUN_ALPACA=false
LIVE_STRATEGIES=crypto_funding_carry,crypto_basis_trade,commodity_carry,crypto_xsmom
MAX_TRADE_USD_GLOBAL=5000
MAX_TRADE_USD_COINBASE=100
MAX_TRADE_USD_ALPACA=100000

# ─── Risk policy ───────────────────────────────────────────────────────
TARGET_PORTFOLIO_VOL=0.12
KILL_DD_PCT=0.15
CRITICAL_DD_PCT=0.10
WARNING_DD_PCT=0.05
RISK_MULTIPLIER=1.0

# ─── Out-of-band alerting (any combination of the three sinks) ─────────
# Pushover phone push (preferred — already set up in your account):
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
# Optional: target a specific device only (default = all your devices)
# PUSHOVER_DEVICE=

# Webhook (Slack/Discord/etc — left blank since both are blocked):
# ALERT_WEBHOOK_URL=

# Email (Gmail SMTP — blank since Gmail App Password is being finicky):
# ALERT_EMAIL_TO=
# SMTP_PASSWORD=

# ─── State persistence (Phase 3.1 — leave blank for now, uses SQLite) ──
# When SUPABASE_URL is set, all state migrates to Postgres:
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# ─── Daily news digest (orthogonal — keeps working) ────────────────────
# SMTP_PASSWORD=
# (or use Gmail App Password if you regenerate one)
